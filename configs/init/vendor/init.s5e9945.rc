on early-init
    mkdir /mnt/vendor/efs 0771 radio system
    mkdir /mnt/vendor/cpefs 0771 radio system
    mkdir /mnt/vendor/persist 0771 system system
    mount debugfs /sys/kernel/debug /sys/kernel/debug

    chown system system /dev/cpuset/tasks
    chown system system /dev/cpuset/cgroup.procs
    chmod 0664 /dev/cpuset/tasks

    # foreground-boost cpuset
    mkdir /dev/cpuset/foreground-boost
    copy /dev/cpuset/cpus /dev/cpuset/foreground-boost/cpus
    copy /dev/cpuset/mems /dev/cpuset/foreground-boost/mems
    chown root system /dev/cpuset/foreground-boost
    chown root system /dev/cpuset/foreground-boost/tasks
    chown root system /dev/cpuset/foreground-boost/cgroup.procs
    chmod 0664 /dev/cpuset/foreground-boost/tasks
    chmod 0664 /dev/cpuset/foreground-boost/cgroup.procs
    write /dev/cpuset/foreground-boost/cpus 0-9

    # set property to boost-optimize
    setprop sys.perf.boostopt true

    # set property to animation vi boost
    setprop sys.perf.viboost true

on init
    # See storage config details at http://source.android.com/tech/storage/
    mkdir /storage/sdcard 0000 root root
    mkdir /storage/usb1 0000 root root
    mkdir /storage/usb2 0000 root root
    mkdir /mnt/media_rw/sdcard 0700 media_rw media_rw
    mkdir /mnt/media_rw/usb1 0700 media_rw media_rw
    mkdir /mnt/media_rw/usb2 0700 media_rw media_rw

    export SECONDARY_STORAGE /storage/sdcard:/storage/usb1:/storage/usb2

   # Change suspend poewr mode to s2idle
    write /sys/power/mem_sleep s2idle

    # Support legacy paths
    symlink /storage/sdcard /mnt/ext_sd
    symlink /data/app /factory

    symlink /dev/block/by-name/steady /dev/block/steady
    symlink /dev/block/by-name/persistent /dev/block/persistent
    symlink /dev/block/by-name/param /dev/block/param

    chown root system /sys/class/sec/gpio/check_requested_gpio
    chmod 0664 /sys/class/sec/gpio/check_requested_gpio

    # Change CPUIdle governor to HALO
    write /sys/devices/system/cpu/cpuidle/current_governor halo

    ## SCSC BT
    chown bluetooth bluetooth /sys/module/scsc_bt/parameters/bluetooth_address

    # Uclamp.min configuration
    write /dev/cpuctl/top-app/cpu.uclamp.min 1
    chown root system /dev/cpuctl/top-app/cpu.uclamp.min
    chmod 0664 /dev/cpuctl/top-app/cpu.uclamp.min

    # Clear sched_util_clamp_min_rt_default
    write /proc/sys/kernel/sched_util_clamp_min_rt_default 0

    # EMS interfaces
    chown system system /dev/ems
    chown system system /sys/kernel/ems/emstune/req_mode
    chown system system /sys/kernel/ems/emstune/req_level
    chown system system /sys/kernel/ems/emstune/aio_tuner
    chown system system /sys/kernel/ems/emstune/reset
    chown system system /sys/kernel/ems/emstune/sched_boost
    chown system system /sys/kernel/ems/emstune/task_boost
    chown system system /sys/kernel/ems/emstune/task_boost_del
    chown system system /sys/kernel/ems/emstune/low_latency
    chown system system /sys/kernel/ems/ego/coregroup0/ratio
    chown system system /sys/kernel/ems/ego/coregroup4/ratio
    chown system system /sys/kernel/ems/ego/coregroup7/ratio
    chown system system /sys/kernel/ems/ego/coregroup9/ratio

    # vendor taskgroup
    chown root system /sys/kernel/ems/taskgroup/background/proc
    chown root system /sys/kernel/ems/taskgroup/background/task
    chown root system /sys/kernel/ems/taskgroup/background/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/background/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/camera-daemon/proc
    chown root system /sys/kernel/ems/taskgroup/camera-daemon/task
    chown root system /sys/kernel/ems/taskgroup/camera-daemon/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/camera-daemon/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/dex2oat/proc
    chown root system /sys/kernel/ems/taskgroup/dex2oat/task
    chown root system /sys/kernel/ems/taskgroup/dex2oat/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/dex2oat/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/foreground/proc
    chown root system /sys/kernel/ems/taskgroup/foreground/task
    chown root system /sys/kernel/ems/taskgroup/foreground/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/foreground/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/midground/proc
    chown root system /sys/kernel/ems/taskgroup/midground/task
    chown root system /sys/kernel/ems/taskgroup/midground/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/midground/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/nnapi-hal/proc
    chown root system /sys/kernel/ems/taskgroup/nnapi-hal/task
    chown root system /sys/kernel/ems/taskgroup/nnapi-hal/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/nnapi-hal/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/rt/proc
    chown root system /sys/kernel/ems/taskgroup/rt/task
    chown root system /sys/kernel/ems/taskgroup/rt/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/rt/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/system/proc
    chown root system /sys/kernel/ems/taskgroup/system/task
    chown root system /sys/kernel/ems/taskgroup/system/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/system/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/system-background/proc
    chown root system /sys/kernel/ems/taskgroup/system-background/task
    chown root system /sys/kernel/ems/taskgroup/system-background/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/system-background/uclamp_min
    chown root system /sys/kernel/ems/taskgroup/top-app/proc
    chown root system /sys/kernel/ems/taskgroup/top-app/task
    chown root system /sys/kernel/ems/taskgroup/top-app/uclamp_max
    chown root system /sys/kernel/ems/taskgroup/top-app/uclamp_min

    chmod 0664 /sys/kernel/ems/taskgroup/background/proc
    chmod 0664 /sys/kernel/ems/taskgroup/background/task
    chmod 0664 /sys/kernel/ems/taskgroup/background/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/background/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/camera-daemon/proc
    chmod 0664 /sys/kernel/ems/taskgroup/camera-daemon/task
    chmod 0664 /sys/kernel/ems/taskgroup/camera-daemon/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/camera-daemon/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/dex2oat/proc
    chmod 0664 /sys/kernel/ems/taskgroup/dex2oat/task
    chmod 0664 /sys/kernel/ems/taskgroup/dex2oat/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/dex2oat/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/foreground/proc
    chmod 0664 /sys/kernel/ems/taskgroup/foreground/task
    chmod 0664 /sys/kernel/ems/taskgroup/foreground/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/foreground/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/midground/proc
    chmod 0664 /sys/kernel/ems/taskgroup/midground/task
    chmod 0664 /sys/kernel/ems/taskgroup/midground/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/midground/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/nnapi-hal/proc
    chmod 0664 /sys/kernel/ems/taskgroup/nnapi-hal/task
    chmod 0664 /sys/kernel/ems/taskgroup/nnapi-hal/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/nnapi-hal/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/rt/proc
    chmod 0664 /sys/kernel/ems/taskgroup/rt/task
    chmod 0664 /sys/kernel/ems/taskgroup/rt/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/rt/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/system/proc
    chmod 0664 /sys/kernel/ems/taskgroup/system/task
    chmod 0664 /sys/kernel/ems/taskgroup/system/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/system/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/system-background/proc
    chmod 0664 /sys/kernel/ems/taskgroup/system-background/task
    chmod 0664 /sys/kernel/ems/taskgroup/system-background/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/system-background/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/top-app/proc
    chmod 0664 /sys/kernel/ems/taskgroup/top-app/task
    chmod 0664 /sys/kernel/ems/taskgroup/top-app/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/top-app/uclamp_min

    # Uclamp.min configuration
    write /sys/kernel/ems/taskgroup/top-app/uclamp_min 1
    chown root system /sys/kernel/ems/taskgroup/top-app/uclamp_min
    chmod 0664 /sys/kernel/ems/taskgroup/top-app/uclamp_min
    write /sys/kernel/ems/taskgroup/midground/uclamp_max 20
    chown root system /sys/kernel/ems/taskgroup/midground/uclamp_max
    chmod 0664 /sys/kernel/ems/taskgroup/midground/uclamp_max

    # sf cpuset
    mkdir /dev/cpuset/sf
    copy /dev/cpuset/cpus /dev/cpuset/sf/cpus
    copy /dev/cpuset/mems /dev/cpuset/sf/mems

    chown system system /dev/cpuset/sf/tasks
    chown system system /dev/cpuset/sf/cgroup.procs
    chown system system /dev/cpuset/sf/cpus

    chmod 0664 /dev/cpuset/sf/cpus
    chown system system /dev/cpuset/sf/cpus
    write /dev/cpuset/sf/cpus 0-8

    chown system system /dev/cpuset/top-app/cpus
    chown system system /dev/cpuset/foreground/cpus
    chown system system /dev/cpuset/background/cpus
    chown system system /dev/cpuset/system-background/cpus
    chown system system /dev/cpuset/cpus
    chmod 0664 /dev/cpuset/top-app/cpus
    chmod 0664 /dev/cpuset/foreground/cpus
    chmod 0664 /dev/cpuset/background/cpus
    chmod 0664 /dev/cpuset/system-background/cpus
    chmod 0664 /dev/cpuset/cpus
    write /dev/cpuset/top-app/cpus 0-9
    write /dev/cpuset/foreground/cpus 0-8
    write /dev/cpuset/background/cpus 0-3
    write /dev/cpuset/system-background/cpus 0-3

    # Apply network parameters for high data performance.
    write /proc/sys/net/core/rmem_default 229376
    write /proc/sys/net/core/rmem_max 16777216
    write /proc/sys/net/core/wmem_default 229376
    write /proc/sys/net/core/wmem_max 8388608
    write /proc/sys/net/core/optmem_max 20480
    write /proc/sys/net/core/netdev_max_backlog 100000
    write /proc/sys/net/ipv4/tcp_rmem "4096 131072 6291456"
    write /proc/sys/net/ipv4/tcp_wmem "4096 16384 4194304"
    write /proc/sys/net/ipv4/tcp_mem "75933 101245 151866"
    write /proc/sys/net/ipv4/udp_mem "151866 202491 303732"
    write /proc/sys/net/ipv4/tcp_adv_win_scale "2"

    # for chub dev
    chmod 0664 /dev/nanohub
    chmod 0664 /dev/nanohub_comms
    chmod 0664 /dev/chub_dev
    chown system system /dev/nanohub
    chown system system /dev/nanohub_comms
    chown system system /dev/chub_dev

    start watchdogd

# Vibrator Firmware load
    chown system system /sys/class/sec_vib_inputff/control/firmware_load
    write /sys/class/sec_vib_inputff/control/firmware_load 0

on post-fs-data
# Log data folder
    mkdir /data/vendor 0771 root system
    mkdir /data/vendor/log 0771 root system
    mkdir /data/vendor/log/abox 0775 audioserver system
    mkdir /data/vendor/log/cbd 0771 root system
    mkdir /data/vendor/log/chub 0771 root system
    mkdir /data/vendor/log/vts 0771 audioserver system

# Permissions for audio
    chmod 0660 /proc/audio/aboxhalflog
    chown audioserver system /proc/audio/aboxhalflog

    chown audioserver system /proc/abox/snapshot_0/log
    chown audioserver system /proc/abox/snapshot_1/log
    chown audioserver system /proc/abox/snapshot_0/valid
    chown audioserver system /proc/abox/snapshot_1/valid
    chown audioserver system /proc/abox/snapshot_0/clear
    chown audioserver system /proc/abox/snapshot_1/clear
    chown audioserver system /proc/abox/dump/log

# Audio abox bigdata
    chown system audio /sys/class/audio/dsp/srcnt
    chown system audio /sys/class/audio/dsp/srcnt_keep

# Audio amp bigdata
    chown system audio /sys/class/audio/amp/temperature_max_0
    chown system audio /sys/class/audio/amp/temperature_keep_max_0
    chown system audio /sys/class/audio/amp/temperature_overcount_0
    chown system audio /sys/class/audio/amp/excursion_max_0
    chown system audio /sys/class/audio/amp/excursion_overcount_0
    chown system audio /sys/class/audio/amp/temperature_max_1
    chown system audio /sys/class/audio/amp/temperature_keep_max_1
    chown system audio /sys/class/audio/amp/temperature_overcount_1
    chown system audio /sys/class/audio/amp/excursion_max_1
    chown system audio /sys/class/audio/amp/excursion_overcount_1

# SSRM Amp temperature
    chown system system /sys/class/audio/amp/surface_temperature_0
    chown system system /sys/class/audio/amp/surface_temperature_1
    chown system system /sys/class/audio/amp/curr_temperature_0
    chown system system /sys/class/audio/amp/curr_temperature_1

# Cirrus Amp Calibration and Factory test
    chown system audio /sys/class/cirrus/cirrus_cal/status
    chown system audio /sys/class/cirrus/cirrus_cal/rdc
    chown system audio /sys/class/cirrus/cirrus_cal/rdc_r
    chown system audio /sys/class/cirrus/cirrus_cal/temp
    chown system audio /sys/class/cirrus/cirrus_cal/temp_r
    mkdir /efs/cirrus 0770 audioserver audio
    chown audioserver audio /efs/cirrus/temp_cal
    chown audioserver audio /efs/cirrus/rdc_cal
    chown audioserver audio /efs/cirrus/rdc_cal_r
    chmod 0660 /efs/cirrus/temp_cal
    chmod 0660 /efs/cirrus/rdc_cal
    chmod 0660 /efs/cirrus/rdc_cal_r
    chown system audio /sys/class/cirrus/cirrus_cal/v_status
    chown system audio /sys/class/cirrus/cirrus_cal/v_validation
    chown system audio /sys/class/cirrus/cirrus_cal/v_validation_r
    chown system audio /sys/class/cirrus/cirrus_cal/isc
    chown system audio /sys/class/cirrus/cirrus_cal/isc_r
    chown system audio /sys/class/cirrus/cirrus_cal/vsc
    chown system audio /sys/class/cirrus/cirrus_cal/vsc_r
    chown audioserver audio /efs/cirrus/isc_cal
    chown audioserver audio /efs/cirrus/isc_cal_r
    chown audioserver audio /efs/cirrus/vsc_cal
    chown audioserver audio /efs/cirrus/vsc_cal_r
    chmod 0660 /efs/cirrus/isc_cal
    chmod 0660 /efs/cirrus/isc_cal_r
    chmod 0660 /efs/cirrus/vsc_cal
    chmod 0660 /efs/cirrus/vsc_cal_r

# Cirrus Amp Bigdata
    chown system audio /sys/class/cirrus/cirrus_bd/max_exc_0
    chown system audio /sys/class/cirrus/cirrus_bd/max_exc_1
    chown system audio /sys/class/cirrus/cirrus_bd/max_temp_0
    chown system audio /sys/class/cirrus/cirrus_bd/max_temp_1
    chown system audio /sys/class/cirrus/cirrus_bd/max_temp_keep_0
    chown system audio /sys/class/cirrus/cirrus_bd/max_temp_keep_1
    chown system audio /sys/class/cirrus/cirrus_bd/over_exc_count_0
    chown system audio /sys/class/cirrus/cirrus_bd/over_exc_count_1
    chown system audio /sys/class/cirrus/cirrus_bd/over_temp_count_0
    chown system audio /sys/class/cirrus/cirrus_bd/over_temp_count_1

# MST/NFC Switch
    chown system system /dev/mst_ctrl
    chmod 0660 /dev/mst_ctrl

# IPSEC PIDDIR for VoWiFi
    mkdir /data/vendor/misc 0771 root system
    mkdir /data/vendor/misc/vpn 0771 radio system

    setprop vold.post_fs_data_done 1
    setprop sys.usb.controller 17900000.dwc3

## SCSC WLAN
    # Setup Wi-Fi permissions
#    mkdir /data/vendor/wifi 0770 wifi system
#    mkdir /data/vendor/wifi/wpa 0770 wifi system
#    mkdir /data/vendor/wifi/wpa/sockets 0770 wifi wifi
#    mkdir /data/vendor/wifi/hostapd/sockets 0770 wifi wifi
#    mkdir /vendor/etc/wifi 0770 system system
#    mkdir /data/vendor/log/wifi 0770 wifi wifi
#    mkdir /data/vendor/conn 0770 wifi wifi
#    chown wifi wifi /sys/wifi/memdump

# Permissions Camera
    mkdir /data/vendor/camera 0777 root root

    chmod 0755 /sys/kernel/debug/tracing
    restorecon /sys/kernel/debug/tracing/trace_marker

# Gatekeeper data
    mkdir /data/vendor/gk 0771 system system
    mkdir /mnt/vendor/persist/gk 0700 system system

# Weaver data
    mkdir /mnt/vendor/persist/weaver 0700 system system
    mkdir /data/vendor/weaver 0700 system system

# Video data
    mkdir /data/vendor/media 0700 mediacodec mediacodec
    mkdir /data/vendor/media/gpu 0700 mediacodec mediacodec

# Permission for GPU
    chown mediacodec system /sys/kernel/gpu/gpu_mm_min_clock
    chmod 0644 /sys/kernel/gpu/gpu_mm_min_clock
    chmod 0000 /sys/class/devfreq/16e00000.sgpu/trans_stat

# Kernel Core Memory - GMR
    chown root system /sys/kernel/gpu/sgpu_swap_ctrl
    chmod 0664 /sys/kernel/gpu/sgpu_swap_ctrl

# HWC data
    mkdir /data/vendor/log/hwc 0771 system graphics

# WFD data
    mkdir /data/vendor/log/wfd 0771 system graphics

# Eden data
    mkdir /data/vendor/eden 0771 system system
    mkdir /data/vendor/eden/gpu 0771 system system

# ENN data
    mkdir /data/vendor/enn 0771 system system

#mAFPC
    exec - system system -- /system/bin/mafpc_write

on boot
    write /proc/sys/vm/swappiness 100

    setprop wifi.interface wlan0

    # SCSC do not enable autorecovery in dev builds
    # write /sys/module/scsc_mx/parameters/disable_recovery_handling 0
    #settings put global captive_portal_mode 0

    # Allow to access debugfs for system:system
    chmod 0755 /sys/kernel/debug
    chown system system /sys/kernel/debug

    setprop ro.radio.noril no

    # Set up kernel tracing, but disable it by default
    chmod 0222 /sys/kernel/debug/tracing/trace_marker
    write /sys/kernel/debug/tracing/tracing_on 0

    # Change permission for A-Box firmware logs file & GPR dump
    chown audioserver system /sys/devices/platform/12050000.abox/0.abox-debug/gicd
    chown audioserver system /sys/devices/platform/12050000.abox/0.abox-debug/gpr
    chown audioserver system /sys/devices/platform/12050000.abox/0.abox-debug/calliope_sram
    chown audioserver system /sys/devices/platform/12050000.abox/0.abox-debug/calliope_dram
    chown audioserver system /sys/devices/platform/12050000.abox/0.abox-debug/calliope_log
    chown audioserver system /sys/devices/platform/12050000.abox/0.abox-debug/calliope_slog
    chown audioserver system /sys/kernel/debug/regmap/12050000.abox/registers
    chown audioserver system /proc/abox/log-00
    chown audioserver system /proc/abox/log-01
    chown audioserver system /proc/abox/qos
    chown audioserver system /proc/abox/failsafe/online
    chown audioserver system /proc/abox/failsafe/reset

# Permission for USB SELECT
    chown system system /sys/class/android_usb/android0/enable
    chmod 0660 /sys/class/android_usb/android0/enable
    chown system system /sys/class/android_usb/android0/idVendor
    chmod 0660 /sys/class/android_usb/android0/idVendor
    chown system system /sys/class/android_usb/android0/idProduct
    chmod 0660 /sys/class/android_usb/android0/idProduct
    chown system system /sys/class/android_usb/android0/f_diag/clients
    chmod 0660 /sys/class/android_usb/android0/f_diag/clients
    chown system system /sys/class/android_usb/android0/functions
    chmod 0660 /sys/class/android_usb/android0/functions
    chown system system /sys/class/android_usb/android0/bDeviceClass
    chmod 0660 /sys/class/android_usb/android0/bDeviceClass

# Ownership and permissions for SEC PM

    # RTC reset status
    chown system system /sys/class/sec/rtc/rtc_status
    chown system system /efs/FactoryApp/rtc_status
    chmod 0664 /efs/FactoryApp/rtc_status

    # PMIC: S2MPS27 manual reset
    chown system system /sys/class/sec/ap_pmic/manual_reset

    # PMIC: S2MPS27 SMPL_WARN count
    chown system system /sys/class/sec/rtc/smpl_warn_cnt

    # PMIC: S2DOS05 Display PMIC
    chown system system /sys/class/sec/disp_pmic/enable_fd

# Permission for UART SWITCH
    chmod 0660 /sys/class/sec/switch/uart_sel
    chown system system /sys/class/sec/switch/uart_sel

# Permission for GPU
    chown mediacodec system /sys/kernel/gpu/gpu_mm_min_clock
    chmod 0664 /sys/kernel/gpu/gpu_mm_min_clock

# bluetooth tty port
    chown bluetooth bluetooth /dev/ttySAC1
    chmod 0660 /dev/ttySAC1

# permissions for bluetooth.
    setprop ro.bt.bdaddr_path "/mnt/vendor/efs/bluetooth/bt_addr"
    chown bluetooth bluetooth ro.bt.bdaddr_path
    chmod 0660 /dev/btpower
    chown bluetooth system /dev/btpower

# for BT MAC address
    mkdir /mnt/vendor/efs/bluetooth 0770 system bluetooth

# if already exist
    chown system bluetooth /mnt/vendor/efs/bluetooth
    chown system bluetooth /mnt/vendor/efs/bluetooth/bt_addr
    chmod 0770 /mnt/vendor/efs/bluetooth
    chmod 0660 /mnt/vendor/efs/bluetooth/bt_addr

# Create directory used for bt chip dump collection
    mkdir /data/vendor/ssrdump 0770 root system

# [ Permissions for Range Sensor Sensor
# Range Sensor
    chown system radio /sys/class/sensors/range_sensor/ambient
    chown system radio /sys/class/sensors/range_sensor/cal01
    chown system radio /sys/class/sensors/range_sensor/cal02
    chown system radio /sys/class/sensors/range_sensor/cal_uid
    chown system radio /sys/class/sensors/range_sensor/open_calibration
    chown system radio /sys/class/sensors/range_sensor/calibration
    chown system radio /sys/class/sensors/range_sensor/enable
    chown system radio /sys/class/sensors/range_sensor/frame_rate
    chown system radio /sys/class/sensors/range_sensor/fw_version
    chown system radio /sys/class/sensors/range_sensor/mode
    chown system radio /sys/class/sensors/range_sensor/name
    chown system radio /sys/class/sensors/range_sensor/range_sigma
    chown system radio /sys/class/sensors/range_sensor/status
    chown system radio /sys/class/sensors/range_sensor/target_status
    chown system radio /sys/class/sensors/range_sensor/temp
    chown system radio /sys/class/sensors/range_sensor/test01
    chown system radio /sys/class/sensors/range_sensor/test02
    chown system radio /sys/class/sensors/range_sensor/test03
    chown system radio /sys/class/sensors/range_sensor/test_mode
    chown system radio /sys/class/sensors/range_sensor/uid
    chown system radio /sys/class/sensors/range_sensor/vendor
    chown system radio /sys/class/sensors/range_sensor/zone
    chown system radio /sys/class/sensors/range_sensor/file_cal
    chown system radio /sys/class/sensors/range_sensor/file_p2p
    chown system radio /sys/class/sensors/range_sensor/file_shape
# ] Permissions for Range Sensor

# SDHMS Slowdown : Cpuset
    write /dev/cpuset/abnormal/cpus 0-3
    write /dev/cpuset/moderate/cpus 0-3

on early-fs
#    write /sys/devices/platform/fmp/fmp-fips/fmp_fips_run 1

on late-fs
    wait_for_prop hwservicemanager.ready true
#    wait_for_prop vendor.sys.mobicoredaemon.enable true
    mount_all /vendor/etc/fstab.${ro.hardware} --late
    swapon_all /vendor/etc/fstab.${ro.hardware}
    
on fs
    start hwservicemanager
    mount_all /vendor/etc/fstab.${ro.hardware} --early

    start insmod_sh_system

    wait /dev/block/by-name/sec_efs
    mount ext4 /dev/block/by-name/sec_efs /efs nosuid nodev noatime noauto_da_alloc,discard,journal_checksum,data=ordered,errors=panic

    setprop ro.crypto.fuse_sdcard true

    restorecon_recursive /mnt/vendor/efs
    restorecon_recursive /mnt/vendor/cpefs
    restorecon_recursive /mnt/vendor/persist

    chown radio system /mnt/vendor/efs
    chmod 0771 /mnt/vendor/efs
    chown radio system /mnt/vendor/cpefs
    chmod 0771 /mnt/vendor/cpefs
    chown radio system /mnt/vendor/persist

    mkdir /mnt/vendor/persist/data/sfs 0700 system system
    mkdir /mnt/vendor/persist/data/tz 0700 system system

# For Range Sensor
    chmod 0660 /dev/range_sensor
    chown system system /dev/range_sensor
    mkdir /data/range_sensor 0770 system system
    mkdir /efs/range_sensor 0770 system system
    chown system system /efs/range_sensor/cal_data.bin
    chmod 0660 /efs/range_sensor/cal_data.bin

    chown system system /efs/range_sensor/vl53l5_cal_shape.bin
    chmod 0660 /efs/range_sensor/vl53l5_cal_shape.bin

    chown system system /efs/range_sensor/vl53l5_cal_p2p.bin
    chmod 0660 /efs/range_sensor/vl53l5_cal_p2p.bin
# Range Sensor

## SCSC WLAN
    # WLBT FW flash update
    write /sys/module/scsc_flash_service/parameters/flash_srv_manual 1

# modem partition for cbd
#    setprop vendor.cbd.partition modem
#    setprop persist.vendor.cbd.btl_size 64

